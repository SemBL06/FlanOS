# Author: Sem Block
# Description: Basic test script

display print text="Starting test" x=0 y=0

set scan to (comm wifi scan)

foreach wifi in scan
    set name to (comm wifi get value=ssid network=wifi)
    display print text=name
end

set test to (math add a=1 b=2)

log info (string concat a="Result: " b=test)

set selected to (ui options list=scan field=ssid selected=0)
ui description text=selected

